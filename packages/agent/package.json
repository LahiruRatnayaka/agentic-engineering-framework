{
  "name": "@agentic-eng/agent",
  "version": "0.2.3",
  "description": "Core agent class and reasoning loop for the EASA framework.",
  "keywords": [
    "agent",
    "ai",
    "framework",
    "typescript",
    "llm",
    "easa"
  ],
  "license": "MIT",
  "author": "Lahiru Ratnayaka",
  "repository": {
    "type": "git",
    "url": "https://github.com/easa-framework/easa.git",
    "directory": "packages/agent"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentic-eng/core": "workspace:*",
    "@agentic-eng/provider": "workspace:*",
    "@agentic-eng/tool": "workspace:*"
  },
  "peerDependencies": {
    "@agentic-eng/memory": "workspace:*",
    "@agentic-eng/observability": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@agentic-eng/memory": {
      "optional": true
    },
    "@agentic-eng/observability": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agentic-eng/memory": "workspace:*",
    "@agentic-eng/observability": "workspace:*",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
